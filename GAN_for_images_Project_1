        "cross_entropy = tf.keras.losses.BinaryCrossentropy()\n",
        "\n",
        "generator_optimizer = tf.keras.optimizers.Adam(0.0002, beta_1=0.5)\n",
        "discriminator_optimizer = tf.keras.optimizers.Adam(0.0002, beta_1=0.5)\n"
